@page
@model DeveloprBud.Pages.TasksModel
@{
    ViewData["Title"] = "Tasks";
}

<div class="container mt-4">

    <div class="text-center mb-4">
        <h1 class="display-5 fw-bold">Tasks</h1>
        <p class="text-muted">Keep yourself accountable and stay organised</p>
    </div>

    <!-- Search (Can search for task name and tag) -->
    <form method="get" class="mb-3 text-center">

        <input type="text"
               name="Search"
               value="@Model.Search"
               class="form-control d-inline-block w-50"
               placeholder="Search Title or Tags..." />

        <button type="submit" class="btn btn-primary btn-sm">
            Search
        </button>

    </form>


    <!-- filter toggle -->
    <div class="text-center mb-3">
        <button class="btn btn-outline-secondary btn-sm"
                data-bs-toggle="collapse"
                data-bs-target="#filterPanel">
            Filters
        </button>
    </div>

    <!-- filter panel -->
    <div class="collapse mb-4" id="filterPanel">

        <form method="get">

            <div class="d-flex flex-wrap justify-content-center gap-2">

                <button type="submit" name="filter" value="All" class="btn btn-sm btn-outline-dark">
                    All
                </button>

                <button type="submit" name="filter" value="High" class="btn btn-sm btn-outline-danger">
                    High Priority
                </button>

                <button type="submit" name="filter" value="Medium" class="btn btn-sm btn-outline-warning">
                    Medium
                </button>

                <button type="submit" name="filter" value="Low" class="btn btn-sm btn-outline-secondary">
                    Low
                </button>
            </div>
        </form>
    </div>

    <div class="text-center mb-4">
        <button type="button"
                class="btn btn-primary"
                data-bs-toggle="modal"
                data-bs-target="#addTaskModal">
            + New Task
        </button>
    </div>

    <!-- Add Task Modal -->
    <div class="modal fade" id="addTaskModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">

                <form method="post" asp-page-handler="AddTask">
                    <div class="modal-header">
                        <h5 class="modal-title">Create Task</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        <div class="mb-3">
                            <label asp-for="NewTask.Title"></label>
                            <input asp-for="NewTask.Title" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewTask.Description"></label>
                            <textarea asp-for="NewTask.Description" class="form-control"></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewTask.Priority"></label>
                            <select asp-for="NewTask.Priority" class="form-select">
                                <option value="">-- Select Priority --</option>
                                @foreach (var level in Model.PriorityLevel)
                                {
                                    <option value="@level">@level</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewTask.Tag"></label>
                            <input asp-for="NewTask.Tag" class="form-control" />
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-primary">
                            Save Task
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- task list -->
    <div class="row g-3">

        @foreach (var task in Model.TaskItems)
        {
            <div class="col-12">

                <div class="card shadow-sm border-0">

                    <div class="card-body position-relative">

                        <h5 class="fw-bold mb-1">@task.Title</h5>

                        <div class="d-flex justify-content-between align-items-center mb-2">

                            <div class="d-flex align-items-center gap-2">

                                @* TAG *@
                                @if (!string.IsNullOrWhiteSpace(task.Tag))
                                {
                                    <span class="badge bg-info">
                                        @task.Tag
                                    </span>
                                }

                                @* PRIORITY *@
                                @if (!string.IsNullOrWhiteSpace(task.Priority))
                                {
                                    <span class="badge
                                                @(task.Priority == "High" ? "bg-danger" :
                                                                                    task.Priority == "Medium" ? "bg-warning" : "bg-secondary")">
                                        @task.Priority
                                    </span>
                                }
                            </div>

                            <small class="text-muted">
                                @task.CreatedDate.ToString("g")
                            </small>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(task.Description))
                        {
                            <hr class="my-3" />

                            <div>
                                <h6 class="text-muted mb-1">Description</h6>
                                <p class="text-secondary mb-0">
                                    @task.Description
                                </p>
                            </div>
                        }

                        <div class="position-absolute top-0 end-0 m-2 d-flex gap-2">
                            <form method="post" asp-page-handler="CompleteTask">
                                <input type="hidden" name="id" value="@task.Id" />
                                <button type="submit" class="btn btn-sm btn-success">
                                    Complete
                                </button>
                            </form>

                            <a asp-page="/EditTask"
                               asp-route-id="@task.Id"
                               class="btn btn-sm btn-warning">
                                Edit
                            </a>

                            <form method="post" asp-page-handler="DeleteTask">
                                <input type="hidden" name="id" value="@task.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}