@page
@model DeveloprBud.Pages.CodeSnippetsModel
@{
    ViewData["Title"] = "Code Snippets";
}

<div class="container mt-4">

    <div class="text-center mb-4">
        <h1 class="display-5 fw-bold">Code Snippets</h1>
        <p class="text-muted">Store, reuse, and manage your code efficiently</p>
    </div>

    <form method="get" class="mb-3 text-center">

        <input type="text"
               name="Search"
               value="@Model.Search"
               class="form-control d-inline-block w-50"
               placeholder="Search Title or Language..." />

        <button type="submit" class="btn btn-primary btn-sm">
            Search
        </button>

    </form>

    <div class="text-center mb-4">
        <button class="btn btn-primary"
                data-bs-toggle="modal"
                data-bs-target="#addSnippetModal">
            + New Code Snippet
        </button>
    </div>

    <!-- add snippet modal -->
    <div class="modal fade" id="addSnippetModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">

                <form method="post" asp-page-handler="AddSnippet">

                    <div class="modal-header">
                        <h5 class="modal-title">Create Code Snippet</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">

                        <div class="mb-3">
                            <label asp-for="NewSnippet.Title"></label>
                            <input asp-for="NewSnippet.Title" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewSnippet.Code"></label>
                            <textarea asp-for="NewSnippet.Code" class="form-control" rows="6"></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewSnippet.Language"></label>
                            <select asp-for="NewSnippet.Language" class="form-select">
                                <option value="">-- Select Language --</option>
                                @foreach (var lang in Model.CodeLanguages)
                                {
                                    <option value="@lang">@lang</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewSnippet.Notes"></label>
                            <textarea asp-for="NewSnippet.Notes" class="form-control"></textarea>
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-primary">
                            Save Snippet
                        </button>
                    </div>

                </form>

            </div>
        </div>
    </div>

    <div class="row g-3">

        @foreach (var snippet in Model.CodeSnippets)
        {
            <pre id="code-@snippet.Id" style="display:none;">@snippet.Code</pre>
            <div class="col-12">

                <div class="card shadow-sm border-0">

                    <div class="card-body position-relative">

                        <h5 class="fw-bold mb-1">@snippet.Title</h5>

                        <div class="d-flex justify-content-between align-items-center mb-2">

                            <span class="badge bg-info">@snippet.Language</span>

                            <small class="text-muted">
                                @snippet.CreatedDate.ToString("g")
                            </small>

                        </div>

                        <!-- Code preview -->
                        <pre style="max-height: 90px;
                            overflow: auto;
                            background-color: #f8f9fa;
                            padding: 10px;
                            border-radius: 6px;">
                            @snippet.Code
                        </pre>

                        <button class="btn btn-sm btn-outline-primary mt-2"
                                data-bs-toggle="modal"
                                data-bs-target="#fullCodeModal-@snippet.Id">
                            View Full Code
                        </button>

                        <button type="button"
                                class="btn btn-sm btn-outline-primary mt-2"
                                onclick="copyCode(@snippet.Id)">
                            Copy Code
                        </button>

                        <hr class="my-3" />

                        <div>
                            <h6 class="text-muted mb-1">Notes</h6>
                            <p class="mb-0 text-secondary">
                                @snippet.Notes
                            </p>
                        </div>

                        <div class="position-absolute top-0 end-0 m-2 d-flex gap-2">

                            <a asp-page="/EditCodeSnippet"
                               asp-route-id="@snippet.Id"
                               class="btn btn-sm btn-warning">
                                Edit
                            </a>

                            <form method="post" asp-page-handler="DeleteSnippet">
                                <input type="hidden" name="id" value="@snippet.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">
                                    Delete
                                </button>
                            </form>

                        </div>

                    </div>

                </div>

            </div>

            <div class="modal fade" id="fullCodeModal-@snippet.Id" tabindex="-1">
                <div class="modal-dialog modal-lg modal-dialog-scrollable">
                    <div class="modal-content">

                        <div class="modal-header">
                            <h5 class="modal-title">@snippet.Title - Full Code</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>

                        <div class="modal-body">
                            <pre style="white-space: pre-wrap;
                                background:#f8f9fa;
                                padding:10px;
                                border-radius:6px;">
                                @snippet.Code
                            </pre>
                        </div>

                        <div class="modal-footer">
                            <button type="button"
                                    class="btn btn-sm btn-outline-primary mt-2"
                                    onclick="copyCode(@snippet.Id)">
                                Copy Code
                            </button>
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                Close
                            </button>
                        </div>

                    </div>
                </div>
            </div>
        }

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>
        function copyCode(id) {
            const el = document.getElementById("code-" + id);

            if (!el) return;

            navigator.clipboard.writeText(el.innerText);
        }
    </script>
}