@page
@model LogoutModel

@{
    ViewData["Title"] = "Logout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">

            <div class="card shadow-sm border-0">
                <div class="card-body p-4 text-center">

                    <img src="~/images/developrbudicon.png" height="60" class="mb-3" />

                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <h3>Ready to leave?</h3>
                        <p class="text-muted">You are about to log out of DeveloprBud.</p>

                        <form method="post"
                              asp-area="Identity"
                              asp-page="/Account/Logout"
                              asp-route-returnUrl="@Url.Page("/", new { area = "" })">

                            <button type="submit" class="btn btn-danger w-100">
                                Logout
                            </button>

                        </form>

                        <a asp-page="/Index" class="d-block mt-3 text-muted">
                            Cancel
                        </a>
                    }
                    else
                    {
                        <h3>You’re logged out</h3>
                        <p class="text-muted">You have successfully logged out of DeveloprBud.</p>

                        <a asp-page="/Index" class="btn btn-primary w-100">
                            Go to Home
                        </a>
                    }

                </div>
            </div>

        </div>
    </div>
</div>